{
  "$ref": "#/definitions/MorphConfig",
  "definitions": {
    "MorphConfig": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "morph": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string",
              "default": "1.0"
            },
            "logLevel": {
              "type": "string",
              "enum": ["debug", "info", "warn", "error"],
              "default": "info"
            },
            "allowConflicts": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "mcpServers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-zA-Z0-9_.-]+$"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "description": {
                "type": "string"
              },
              "labels": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "aliases": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "transport": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "stdio"
                      },
                      "command": {
                        "type": "string",
                        "minLength": 1
                      },
                      "args": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "default": []
                      },
                      "env": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "cwd": {
                        "type": "string"
                      },
                      "timeoutMs": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": ["type", "command"],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "http"
                      },
                      "url": {
                        "type": "string",
                        "format": "uri"
                      },
                      "headers": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "apiKey": {
                        "type": "string"
                      }
                    },
                    "required": ["type", "url"],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "sse"
                      },
                      "url": {
                        "type": "string",
                        "format": "uri"
                      },
                      "headers": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "reconnectIntervalMs": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": ["type", "url"],
                    "additionalProperties": false
                  }
                ]
              }
            },
            "required": ["name", "transport"],
            "additionalProperties": false
          },
          "default": []
        },
        "toon": {
          "type": "object",
          "properties": {
            "autoConvert": {
              "type": "boolean",
              "default": true
            },
            "delimiter": {
              "type": "string",
              "enum": ["comma", "tab", "pipe"],
              "default": "comma"
            },
            "indent": {
              "type": "integer",
              "minimum": 0,
              "maximum": 8,
              "default": 2
            },
            "flattenDepth": {
              "type": "integer",
              "minimum": 0,
              "default": 4
            },
            "threshold": {
              "type": "integer",
              "minimum": 0,
              "default": 100
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "webUi": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "host": {
              "type": "string",
              "default": "0.0.0.0"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 3100
            },
            "auth": {
              "type": "object",
              "properties": {
                "username": {
                  "type": "string"
                },
                "passwordHash": {
                  "type": "string"
                }
              },
              "required": ["username", "passwordHash"],
              "additionalProperties": false
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "health": {
          "type": "object",
          "properties": {
            "intervalMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 30000
            },
            "timeoutMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 5000
            },
            "maxRetries": {
              "type": "integer",
              "minimum": 0,
              "default": 3
            }
          },
          "additionalProperties": false,
          "default": {}
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
