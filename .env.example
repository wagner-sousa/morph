# MORPH environment variables
# Copy to .env and fill in. .env is gitignored.

# --- Backend MCP secrets (referenced as ${VAR} in morph.json) ---
# CLICKUP_API_KEY=pk_xxxxx
# BRIGHTDATA_API_KEY=bd_xxxxx
# PG_USER=admin
# PG_PASS=change_me

# --- Web UI Basic Auth (optional; if unset, auth is disabled) ---
# MORPH_WEB_USERNAME=admin
# MORPH_WEB_PASSWORD=change_me

# --- Runtime ---
# MORPH_CONFIG=./morph.json
# MORPH_DATA_DIR=./data
# MORPH_TRANSPORT=stdio        # stdio | http
# MORPH_SHUTDOWN_TIMEOUT=10000
# CORS_ORIGIN=https://studio.example.com
