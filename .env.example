# MORPH environment variables
# Copy to .env and fill in. .env is gitignored.
#
# Every MORPH_* var below overrides the matching value in morph.json. Precedence:
#   CLI flag  >  env var (below)  >  morph.json  >  built-in default

# --- Backend MCP secrets (referenced as ${VAR} inside .mcp.json) ---
# CLICKUP_API_KEY=pk_xxxxx
# BRIGHTDATA_API_KEY=bd_xxxxx
# PG_USER=admin
# PG_PASS=change_me

# --- Docker user mapping (so files in ./data are owned by the host user) ---
UID=1000
GID=1000

# --- Data / config / logs (single folder) ---
# MORPH_DATA_DIR=./data            # db, logs and config all live here
# MORPH_CONFIG=./data/morph.json   # explicit path (else <data>/morph.json or ./morph.json)
# MORPH_MCP_CONFIG=./data/.mcp.json
# MORPH_LOG_FILE=true              # also write <data>/logs/morph.log (default: off)
# MORPH_LOG_DIR=./data/logs

# --- Runtime ---
# MORPH_TRANSPORT=stdio            # stdio | http
# MORPH_SHUTDOWN_TIMEOUT=10000
# CORS_ORIGIN=https://studio.example.com

# --- morph ---
# MORPH_LOG_LEVEL=info             # debug | info | warn | error
# MORPH_ALLOW_CONFLICTS=false
# MORPH_TOOL_PREFIX=

# --- Web UI ---
# MORPH_WEB_ENABLED=true
# MORPH_WEB_HOST=0.0.0.0
# MORPH_WEB_PORT=3100
# MORPH_WEB_PUBLIC_URL=http://localhost:3101
# MORPH_WEB_USERNAME=admin         # set both to enable Basic Auth
# MORPH_WEB_PASSWORD=change_me

# --- TOON conversion ---
# MORPH_TOON_AUTO_CONVERT=true
# MORPH_TOON_DELIMITER=comma       # comma | tab | pipe
# MORPH_TOON_INDENT=2
# MORPH_TOON_FLATTEN_DEPTH=4
# MORPH_TOON_THRESHOLD=100

# --- Health checks ---
# MORPH_HEALTH_INTERVAL_MS=30000
# MORPH_HEALTH_TIMEOUT_MS=5000
# MORPH_HEALTH_MAX_RETRIES=3
