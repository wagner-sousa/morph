{
  "$schema": "./schema.json",
  "morph": {
    "version": "1.0",
    "logLevel": "info",
    "allowConflicts": false
  },
  "mcpServers": [
    {
      "name": "demo",
      "enabled": true,
      "description": "Demo MCP over stdio (ping/users/echo tools)",
      "transport": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "tsx",
          "src/examples/demo-mcp-server.ts"
        ]
      }
    },
    {
      "name": "demo-http",
      "enabled": true,
      "description": "Demo MCP over Streamable HTTP (port 3200)",
      "transport": {
        "type": "http",
        "url": "http://mcp-test-servers:3200/mcp"
      }
    },
    {
      "name": "demo-sse",
      "enabled": true,
      "description": "Demo MCP over SSE legacy (port 3201)",
      "transport": {
        "type": "sse",
        "url": "http://mcp-test-servers:3201/sse"
      }
    },
    {
      "name": "demo-http",
      "enabled": true,
      "description": "Demo HTTP MCP server (runs on port 3200)",
      "transport": {
        "type": "http",
        "url": "http://localhost:3200/mcp"
      }
    }
  ],
  "toon": {
    "autoConvert": true,
    "delimiter": "comma",
    "indent": 2,
    "flattenDepth": 4,
    "threshold": 100
  },
  "webUi": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 3101
  },
  "health": {
    "intervalMs": 30000,
    "timeoutMs": 5000,
    "maxRetries": 3
  }
}
